# Copy this file to .env and set strong values before production deploy.

NODE_ENV=production
PORT=3001
APP_DOMAIN=anupro.me
TRUST_PROXY=true

# Admin login username
ADMIN_USER=admin

# bcrypt hash only (do not store plaintext password here)
# Example generation (from project root):
# node -e "const bcrypt=require('bcryptjs'); console.log(bcrypt.hashSync('YOUR_STRONG_PASSWORD', 10));"
ADMIN_PASSWORD_HASH=

# Strong random session secret (32+ chars)
SESSION_SECRET=
